#!/sbin/sh
SKIPUNZIP=1
MODID="screenshot_rotate_fix"
MODPATH="${NVBASE}/modules/$MODID"

. /data/adb/magisk/util_functions.sh

mkdir -p "$MODPATH/tools"

unzip -o "$ZIPFILE" "module.prop" -d "$MODPATH" >&2
unzip -o "$ZIPFILE" "customize.sh" -d "$MODPATH" >&2
unzip -o "$ZIPFILE" "service.sh" -d "$MODPATH" >&2
unzip -o "$ZIPFILE" "action.sh" -d "$MODPATH" >&2
unzip -o "$ZIPFILE" "config.sh" -d "$MODPATH" >&2
unzip -o "$ZIPFILE" "README.md" -d "$MODPATH" >&2
unzip -o "$ZIPFILE" "update.json" -d "$MODPATH" >&2
unzip -o "$ZIPFILE" "CHANGELOG.md" -d "$MODPATH" >&2
unzip -o "$ZIPFILE" "tools/*" -d "$MODPATH" >&2

set_perm_recursive "$MODPATH/tools" root root 0755 0755
set_perm "$MODPATH/service.sh" root root 0755
set_perm "$MODPATH/action.sh" root root 0755
set_perm "$MODPATH/customize.sh" root root 0755
set_perm "$MODPATH/config.sh" root root 0755

. "$MODPATH/customize.sh"
